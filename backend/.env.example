# MongoDB Atlas 接続文字列
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# データベース名
MONGODB_DB_NAME=teamboard

# JWT 署名鍵（本番では openssl rand -hex 32 で生成した値を使用）
JWT_SECRET_KEY=your-strong-random-secret-key-here

# JWT アクセストークン有効期限（分）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# フロントエンドの CloudFront URL（複数の場合はカンマ区切り）
CORS_ORIGINS=https://xxxxxxxxxx.cloudfront.net

# アクセスを許可するメールアドレス（カンマ区切り、空の場合は全員許可）
ALLOWED_EMAILS=user1@example.com,user2@example.com
